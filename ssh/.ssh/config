HashKnownHosts no
ForwardAgent yes
StrictHostKeyChecking no
ForwardX11 yes
ConnectTimeout 30
AddKeysToAgent yes

### PASARELA
host atlas.unc.edu.ar
	hostname atlas.unc.edu.ar
	user bgenero
	ProxyCommand none
	IdentityFile ~/.ssh/psi_rsa

### SERVIDORES UNC
host *.unc.edu.ar !atlas.unc.edu.ar !gitlab.unc.edu.ar
	user root
	ProxyCommand ssh -W %h:%p atlas.unc.edu.ar
	IdentityFile ~/.ssh/psi_rsa

### PSI-UNC GitLab
Host gitlab.unc.edu.ar
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_gitlab

  ### ControlNet Gitlab
Host gitlab.controlnet.com.ar
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/controlnet_gitlab_key
